# =============================================================================
# GTO API Server Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp config/.env.example config/.env
#
# The server reads env vars in this order:
#   1. config/.env  (dotenvy::from_filename)
#   2. .env at project root (dotenvy::dotenv)
#   3. System environment variables
#
# Code reference: api/src/main.rs
# =============================================================================

# --- Server ---

# HTTP port for the API server
# Used at: main.rs:28 -> HttpServer::bind("0.0.0.0", PORT)
# Default: 3001
PORT=3001

# Log level filter for env_logger
# Used at: main.rs:26 -> env_logger::init()
# Values: error, warn, info, debug, trace
# Default: (none - no logs unless set)
RUST_LOG=info

# --- Data Source ---

# Controls where solver tree data is loaded from
# Used at: main.rs:33 -> match source_type
# Values:
#   "local" = read from local filesystem (development)
#   "s3"    = read from AWS S3 bucket (production)
# Default: "local"
DATA_SOURCE=local

# --- Local Mode (DATA_SOURCE=local) ---

# Path to the solver output directory
# Used at: main.rs:51 -> DataSource::Local { path }
# This directory contains stack folders, e.g.:
#   output/
#     10 17 54 17 15 32 21 29/    <- folder name = stacks / 10M
#       settings.json              <- solver config (stacks, blinds, ICM)
#       equity.json                <- pre-hand equity + bubble factors
#       nodes/                     <- game tree (~3000 node files)
#         0.json                   <- root node (UTG to act)
#         1.json                   <- after UTG folds
#         ...
#
# Where to get this data:
#   - Generated by the GTO solver (e.g., desktop-postflop, MonkerSolver)
#   - Each run produces one stack folder
#   - See output/ in the spec project for an example
# Default: "output"
DATA_PATH=../output

# --- S3 Mode (DATA_SOURCE=s3) ---

# AWS region where the S3 bucket is located
# Used at: main.rs:37 -> aws_config::Region::new(region)
# Where to find: AWS Console -> S3 -> your bucket -> Properties -> Region
# Default: "ap-southeast-1"
AWS_REGION=ap-southeast-1

# IAM credentials for S3 access
# Used at: main.rs:41 -> aws_config::defaults().load()
# Where to get:
#   - AWS Console -> IAM -> Users -> Security credentials -> Create access key
#   - Or use EC2 instance role / ECS task role (leave blank, SDK auto-detects)
# Required permissions: s3:GetObject, s3:ListBucket on the target bucket
# If running on AWS (EC2/ECS/Lambda), leave blank to use instance role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket name containing the solver data
# Used at: main.rs:38 -> S3_BUCKET (required when DATA_SOURCE=s3)
# Where to find: AWS Console -> S3 -> bucket name
# The bucket should contain: {S3_PREFIX}/{stack_folder}/settings.json, nodes/, etc.
# REQUIRED when DATA_SOURCE=s3 (server will panic if missing)
S3_BUCKET=

# Key prefix inside the S3 bucket
# Used at: main.rs:39 -> S3_PREFIX
# The full S3 key for a node file:
#   s3://{S3_BUCKET}/{S3_PREFIX}/{stack_folder}/nodes/0.json
# Example: if your bucket has "output/10 17 54 .../nodes/0.json", set prefix to "output"
# Default: "output"
S3_PREFIX=output
